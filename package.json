    "reset-db": "prisma migrate reset",
    "start": "next start",
    "studio": "prisma studio",
    "test": "vitest run",
    "test:e2e": "cypress run --browser chrome",
    "test:watch": "vitest",
    "vitest": "vitest --ui"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
